{
  "name": "nestjs-boilerplate",
  "version": "1.0.0",
  "description": "A comprehensive NestJS boilerplate with authentication, logging, database, caching, and more",
  "author": "m1ngshum",
  "license": "MIT",
  "keywords": [
    "nestjs",
    "boilerplate",
    "typescript",
    "authentication",
    "logging",
    "database",
    "caching",
    "sentry"
  ],
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "repl": "nest start --entryFile repl",
    "repl:dev": "nest start --debug --watch --entryFile repl",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "lint:strict": "eslint \"src/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migration:create": "ts-node scripts/create-migration.ts",
    "db:migration:up": "npx mikro-orm migration:up",
    "db:migration:down": "npx mikro-orm migration:down",
    "db:seed": "npx mikro-orm seeder:run",
    "setup:new-project": "node scripts/setup-new-project.js",
    "update:boilerplate": "node scripts/update-boilerplate.js",
    "check:boilerplate": "node scripts/check-boilerplate-version.js",
    "yarn:upgrade": "yarn upgrade-interactive",
    "yarn:why": "yarn why @nestjs/core",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.0.0",
    "@mikro-orm/core": "^7.0.8",
    "@mikro-orm/migrations": "^7.0.8",
    "@mikro-orm/nestjs": "^7.0.1",
    "@mikro-orm/postgresql": "^7.0.8",
    "@mikro-orm/reflection": "^7.0.8",
    "@mikro-orm/seeder": "^7.0.8",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@sentry/nestjs": "^10.47.0",
    "@sentry/profiling-node": "^10.47.0",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "date-fns": "^4.1.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "iovalkey": "^0.3.3",
    "ip-address": "^10.1.0",
    "nestjs-cls": "^6.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "path-to-regexp": "^8.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ua-parser-js": "^2.0.9",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@golevelup/ts-jest": "^3.0.0",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/path-to-regexp": "^1.7.0",
    "@types/supertest": "^7.2.0",
    "@types/ua-parser-js": "^0.7.39",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "!src/**/*.spec.ts",
      "!src/**/*.interface.ts",
      "!src/main.ts"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleDirectories": [
      "<rootDir>",
      "node_modules",
      "src"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.ts"
    ]
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.0",
      "handlebars": ">=4.7.9",
      "picomatch": ">=4.0.4",
      "flatted": ">=3.4.2",
      "serialize-javascript": ">=7.0.5",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "file-type": ">=21.3.2",
      "path-to-regexp": ">=8.4.0"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
