# Application Configuration
NODE_ENV=development
APP_NAME=nestjs-boilerplate
APP_PORT=3000
APP_HOST=localhost
APP_URL=http://localhost:3000

# Docker Compose Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
REDIS_PASSWORD=changeme

# Database Configuration (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=changeme
DATABASE_NAME=nestjs_boilerplate
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false
DATABASE_SSL=false
DATABASE_AUTO_MIGRATE=false

# Read Replica (optional - single replica via env vars)
# DATABASE_READ_REPLICA_HOST=localhost
# DATABASE_READ_REPLICA_PORT=5432
# DATABASE_READ_REPLICA_USERNAME=postgres
# DATABASE_READ_REPLICA_PASSWORD=changeme
# DATABASE_READ_REPLICA_NAME=nestjs_boilerplate
# DATABASE_READ_REPLICA_WEIGHT=1

# Read Replicas (optional - multiple replicas via JSON)
# DATABASE_READ_REPLICAS=[{"host":"replica1","port":5432,"username":"postgres","password":"changeme","database":"nestjs_boilerplate","weight":1}]

# Valkey/Redis Configuration (optional - leave empty to use in-memory cache)
# VALKEY_CLUSTER_HOST=localhost
# VALKEY_CLUSTER_PORT=6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
CACHE_TTL=300

# Sentry Configuration (optional - leave empty to disable)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
THROTTLE_ENABLED=true
THROTTLE_TTL=60
THROTTLE_LIMIT=10
# THROTTLE_SKIP_SUCCESSFUL=false
# THROTTLE_SKIP_FAILED=false
# THROTTLE_BLOCK_DURATION=300
# THROTTLE_CUSTOM_PATHS=[{"path":"/v1/auth/login","limit":5,"ttl":60,"blockDuration":300}]

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true
# CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
# CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept
# CORS_DOMAINS=
# CORS_PRODUCTION_DOMAINS=
# CORS_TESTING_DOMAINS=
# CORS_ROUTES_JSON=[]

# Swagger Configuration
SWAGGER_ENABLED=true
SWAGGER_TITLE=NestJS Boilerplate API
SWAGGER_DESCRIPTION=A comprehensive NestJS boilerplate API
SWAGGER_VERSION=1.0.0
SWAGGER_PATH=docs

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_DATABASE_ENABLED=true
HEALTH_CHECK_REDIS_ENABLED=true

# Security Configuration
# SECURITY_HSTS_ENABLED=true
# SECURITY_HSTS_MAX_AGE=31536000
# SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
# SECURITY_HSTS_PRELOAD=true
# SECURITY_CSP_ENABLED=true
# SECURITY_CSP_REPORT_ONLY=false
# SECURITY_CSP_DEFAULT_SRC='self'
# SECURITY_CSP_SCRIPT_SRC='self'
# SECURITY_CSP_STYLE_SRC='self'
# SECURITY_CSP_IMG_SRC='self',data:,https:
# SECURITY_CSP_FONT_SRC='self',https:,data:
# SECURITY_CSP_CONNECT_SRC='self'
# SECURITY_FRAME_OPTIONS=deny
# SECURITY_CONTENT_TYPE_OPTIONS=true
# SECURITY_REFERRER_POLICY=no-referrer
