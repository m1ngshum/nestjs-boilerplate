# Production Docker ignore file
# Optimized for minimal image size and security

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store

# Build outputs (will be built in container)
dist
build
*.tsbuildinfo

# Environment files (handled by ECS/secrets)
.env*
!.env.example

# Development files
.git
.gitignore
README.md
CHANGELOG.md
LICENSE
*.md
docs/

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Test files
coverage
.nyc_output
test
tests
**/*.spec.ts
**/*.test.ts
**/*.spec.js
**/*.test.js

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage
*.lcov

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Parcel cache
.cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# Docker files (except production)
Dockerfile
docker-compose*.yml
.dockerignore

# Scripts (not needed in production)
scripts/

# GitHub workflows
.github/

# CI/CD files
.gitlab-ci.yml
.travis.yml
.circleci/

# Private keys and certificates
*.pem
*.key
*.crt
*.p12
*.pfx

# Database files
*.db
*.sqlite
*.sqlite3

# Backup files
*.bak
*.backup

# Lock files (keep pnpm-lock.yaml)
package-lock.json
yarn.lock

# Husky files
.husky/

# Lint staged
.lintstagedrc*

# Prettier
.prettierrc*
.prettierignore

# ESLint
.eslintrc*
.eslintignore

# Jest
jest.config.*
jest.setup.*

# Babel
.babelrc*
babel.config.*

# Webpack
webpack.config.*

# Rollup
rollup.config.*

# Vite
vite.config.*

# Turbo
turbo.json

# Nx
nx.json
.nx/

# Lerna
lerna.json

# Rush
rush.json
common/

# Rushstack
rushstack.json

# Rushstack build cache
common/temp/

# Rushstack build outputs
lib/
lib-commonjs/
lib-esm/

# Rushstack test outputs
lib-test/

# Rushstack temp
temp/

# Rushstack node_modules
node_modules/

# Rushstack package manager
common/autoinstallers/

# Rushstack build cache
common/temp/

# Rushstack build outputs
lib/
lib-commonjs/
lib-esm/

# Rushstack test outputs
lib-test/

# Rushstack temp
temp/

# Rushstack node_modules
node_modules/

# Rushstack package manager
common/autoinstallers/
